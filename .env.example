# Repo-wide environment. Copy to .env at the repo root: `cp .env.example .env`.
#
# All backend secret values are tracked in a self-hosted secret-party instance
# (https://github.com/0916dhkim/secret-party) and fetched at runtime. There is
# no plaintext fallback — secret-party is required, including for local dev.
#
# The secret values themselves (database URL, ingest token, ...) live in
# secret-party; the canonical list is the SECRETS manifest in
# apps/web/src/secrets.ts. Only the connection config for reaching secret-party
# is set here, and it is shared by the backend and the worker's deploy sync:

SECRETS_BASE_URL=https://secrets.example.com
SECRETS_ENVIRONMENT_ID=
SECRETS_PRIVATE_KEY=

# Docker Compose / Dokploy deployment only.
# Not needed for local dev — only for `docker compose up`.
#
# CLOUDFLARE_API_TOKEN authenticates `wrangler deploy` from the worker-deployer
# sidecar. CLOUDFLARE_ACCOUNT_ID is optional (omit if the token is scoped to a
# single account). INGEST_URL is the public backend URL the worker forwards
# mail to — it overrides the placeholder in apps/worker/wrangler.toml at
# deploy time.

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
INGEST_URL=https://app.example.com/api/ingest
